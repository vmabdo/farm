# ============================================================
# DATABASE (PostgreSQL - Required for Production / Vercel)
# ============================================================
# Paste your Neon / Supabase / Railway connection string below.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/farm_erp?sslmode=require"

# ============================================================
# AUTH SECRET (Used for JWT session signing)
# ============================================================
# Generate a strong random value: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret"
