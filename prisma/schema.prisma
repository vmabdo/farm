// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Breed Management
model Breed {
  id         String   @id @default(cuid())
  name       String   @unique
  pricePerKg Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cattle     Cattle[]
}

// 2. Cattle & Weights Management
model Cattle {
  id                  String         @id @default(cuid())
  tagNumber           String         @unique
  breedId             String?
  breed               Breed?         @relation(fields: [breedId], references: [id])
  entryDate           DateTime       @default(now())
  entryWeight         Float
  currentWeight       Float?
  status              String         @default("ACTIVE") // ACTIVE, SOLD, DECEASED
  buyerName           String?
  invoiceSerialNumber Int?
  lastWeightDifference Float?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  weights             WeightRecord[]
  medical             MedicalRecord[]
}

model WeightRecord {
  id        String   @id @default(cuid())
  cattleId  String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  cattle    Cattle   @relation(fields: [cattleId], references: [id], onDelete: Cascade)
}

// 2. Feed & Inventory
model FeedItem {
  id           String   @id @default(cuid())
  name         String
  type         String
  currentStock Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       FeedPurchaseOrder[]
  consumptions FeedConsumption[]
}

model FeedPurchaseOrder {
  id           String   @id @default(cuid())
  feedId       String
  quantity     Float
  unit         String
  pricePerUnit Float
  totalCost    Float
  date         DateTime @default(now())
  supplier     String?
  feedItem     FeedItem @relation(fields: [feedId], references: [id], onDelete: Cascade)
}

model FeedConsumption {
  id          String   @id @default(cuid())
  feedItemId  String
  quantity    Float
  unit        String   @default("كيلو")
  date        DateTime @default(now())
  notes       String?
  feedItem    FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
}

// 3. Workers & Payroll
model Worker {
  id         String    @id @default(cuid())
  name       String
  nationalId String    @unique
  role       String
  phone      String?
  startDate  DateTime  @default(now())
  salary     Float
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  payrolls   Payroll[]
}

model Payroll {
  id          String   @id @default(cuid())
  workerId    String
  amount      Float
  paymentDate DateTime @default(now())
  type        String   // SALARY, BONUS, DEDUCTION
  notes       String?
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

// 4. Medical Care & Vaccinations
model Medicine {
  id             String   @id @default(cuid())
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  records        MedicalRecord[]
  orders         MedicalPurchaseOrder[]
}

model MedicalPurchaseOrder {
  id           String   @id @default(cuid())
  medicineId   String
  quantity     Float
  unit         String
  pricePerUnit Float
  totalCost    Float
  date         DateTime @default(now())
  medicine     Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id            String   @id @default(cuid())
  cattleId      String
  medicineId    String
  dose          Float
  unit          String   @default("جرعة")
  treatmentDate DateTime @default(now())
  type          String   // VACCINE, TREATMENT
  notes         String?
  cattle        Cattle   @relation(fields: [cattleId], references: [id], onDelete: Cascade)
  medicine      Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

// 5. Transportation & Expenses
model TransportRent {
  id          String   @id @default(cuid())
  vehicleType String
  driverName  String?
  cost        Float
  purpose     String   // FEED_DELIVERY, CATTLE_TRANSPORT, OTHER
  travelDate  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Authentication
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Equipment & Machinery
model Equipment {
  id        String   @id @default(cuid())
  name      String
  type      String   // TRACTOR, LOADER, GENERATOR, OTHER
  status    String   @default("ACTIVE") // ACTIVE, MAINTENANCE, OUT_OF_SERVICE
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  maintenances EquipmentMaintenance[]
}

model EquipmentMaintenance {
  id          String   @id @default(cuid())
  equipmentId String
  description String
  cost        Float
  date        DateTime @default(now())
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
}

// 7. Invoices & Reports
model Invoice {
  id           String   @id @default(cuid())
  serialNumber Int      @default(autoincrement())
  clientName   String
  invoiceDate  DateTime @default(now())
  totalAmount Float
  discount    Float    @default(0)
  netAmount   Float
  items       String   // JSON string of invoice items
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
// 8. General Expenses (المصروفات العامة)
model GeneralExpense {
  id        String   @id @default(cuid())
  itemName  String
  cost      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

// 9. Farm Settings (إعدادات المزرعة)
// Singleton record — always uses id = 1
model FarmSettings {
  id       Int     @id @default(1)
  farmName String  @default("مزرعتي")
  logoData String? @db.Text  // Base64-encoded image string
}
