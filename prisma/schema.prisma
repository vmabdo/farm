// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Breed Management
model Breed {
  id         String   @id @default(cuid())
  name       String   @unique
  pricePerKg Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cattle     Cattle[]
}

// 2. Cattle & Weights Management
model Cattle {
  id                  String         @id @default(cuid())
  tagNumber           String         @unique
  breedId             String?
  breed               Breed?         @relation(fields: [breedId], references: [id])
  entryDate           DateTime       @default(now())
  entryWeight         Float
  currentWeight       Float?
  status              String         @default("ACTIVE") // ACTIVE, SOLD, DECEASED
  buyerName           String?
  invoiceSerialNumber Int?
  lastWeightDifference Float?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  weights             WeightRecord[]
  medical             MedicalRecord[]
}

model WeightRecord {
  id        String   @id @default(cuid())
  cattleId  String
  weight    Float
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  cattle    Cattle   @relation(fields: [cattleId], references: [id], onDelete: Cascade)
}

// 2. Feed & Inventory
model FeedItem {
  id           String   @id @default(cuid())
  name         String
  type         String
  currentStock Float    @default(0)
  unit         String   // KG, TON, BAG
  dailyPrice   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       FeedOrder[]
  consumptions FeedConsumption[]
}

model FeedOrder {
  id          String   @id @default(cuid())
  feedItemId  String
  quantity    Float
  orderDate   DateTime @default(now())
  cost        Float
  supplier    String?
  feedItem    FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
}

model FeedConsumption {
  id          String   @id @default(cuid())
  feedItemId  String
  quantity    Float
  date        DateTime @default(now())
  notes       String?
  feedItem    FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
}

// 3. Workers & Payroll
model Worker {
  id         String    @id @default(cuid())
  name       String
  nationalId String    @unique
  role       String
  phone      String?
  startDate  DateTime  @default(now())
  salary     Float
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  payrolls   Payroll[]
}

model Payroll {
  id          String   @id @default(cuid())
  workerId    String
  amount      Float
  paymentDate DateTime @default(now())
  type        String   // SALARY, BONUS, DEDUCTION
  notes       String?
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

// 4. Medical Care & Vaccinations
model Medicine {
  id             String   @id @default(cuid())
  name           String
  supplier       String?
  currentStock   Float    @default(0)
  unit           String   // ML, DOSE, BOTTLE
  expirationDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  records        MedicalRecord[]
}

model MedicalRecord {
  id            String   @id @default(cuid())
  cattleId      String
  medicineId    String
  dose          Float
  treatmentDate DateTime @default(now())
  type          String   // VACCINE, TREATMENT
  notes         String?
  cattle        Cattle   @relation(fields: [cattleId], references: [id], onDelete: Cascade)
  medicine      Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
}

// 5. Transportation & Expenses
model TransportRent {
  id          String   @id @default(cuid())
  vehicleType String
  driverName  String?
  cost        Float
  purpose     String   // FEED_DELIVERY, CATTLE_TRANSPORT, OTHER
  travelDate  DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Authentication
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Equipment & Machinery
model Equipment {
  id        String   @id @default(cuid())
  name      String
  type      String   // TRACTOR, LOADER, GENERATOR, OTHER
  status    String   @default("ACTIVE") // ACTIVE, MAINTENANCE, OUT_OF_SERVICE
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 7. Invoices & Reports
model Invoice {
  id           String   @id @default(cuid())
  serialNumber Int      @default(autoincrement())
  clientName   String
  invoiceDate  DateTime @default(now())
  totalAmount Float
  discount    Float    @default(0)
  netAmount   Float
  items       String   // JSON string of invoice items
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
